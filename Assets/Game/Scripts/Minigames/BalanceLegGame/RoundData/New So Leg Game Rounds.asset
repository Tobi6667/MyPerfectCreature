  rounds:
  - roundId: H
    instruction: "POST-ASSEMBLY CALIBRATION\n\nYour newly acquired leg has passed
      all visual inspections.\n\nUnfortunately, nobody checked whether it can stand.\n\nKeep
      the leg balanced while the laboratory's highly scientific \"Push Machine\"
      delivers random impacts.\n\nControls:\n\U0001F5B1 Move the mouse to maintain
      balance.\n\U0001F4A5 Recover from sudden pushes."
    showInstruction: 1
    duration: 15
    targetScore: 3
    rootMoveMultiplier: 11.33
    randomPushForce: 1.03
    randomPushIntervalMin: 1.17
    randomPushIntervalMax: 2.05
    failDistance: 1.55
    gravity: 1.86
    stiffness: 0.58
    damping: 0.44
    maxOffset: 7.64
    controlResponsiveness: 0.94
  - roundId: LL
    instruction: Ready for Round 2?!
